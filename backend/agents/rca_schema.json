{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RCA Report",
  "description": "Structured Root Cause Analysis report produced by the RCA agent",
  "type": "object",
  "required": [
    "anomaly_id",
    "window_utc",
    "severity",
    "root_cause",
    "evidence",
    "impact",
    "recommendations"
  ],
  "additionalProperties": true,
  "properties": {
    "anomaly_id": {
      "type": "string",
      "description": "Identifier of the anomaly being investigated"
    },
    "window_utc": {
      "type": "object",
      "description": "UTC time window of the anomaly",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "string",
          "description": "ISO 8601 start timestamp (UTC)"
        },
        "end": {
          "type": "string",
          "description": "ISO 8601 end timestamp (UTC)"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["P1", "P2", "P3", "P4"],
      "description": "Incident severity. P1=complete outage or data loss, P2=major user-facing degradation, P3=partial degradation, P4=minor or internal-only issue"
    },
    "affected_services": {
      "type": "array",
      "description": "List of services showing anomalies",
      "items": {
        "type": "object",
        "required": ["service", "anomaly_type"],
        "properties": {
          "service": {
            "type": "string",
            "description": "Service name"
          },
          "anomaly_type": {
            "type": "string",
            "description": "Type of anomaly (e.g., latency, error_rate, unavailable, cpu_spike)"
          },
          "details": {
            "type": "string",
            "description": "Detailed description of the anomaly with verbatim metric values and timestamps"
          },
          "peak_time_utc": {
            "type": ["string", "null"],
            "description": "UTC timestamp of peak anomaly"
          }
        }
      }
    },
    "root_cause": {
      "type": "object",
      "description": "Root cause analysis",
      "required": ["confidence", "confidence_rationale", "failure_domain", "failure_mode", "summary", "causal_chain", "alternatives_considered"],
      "properties": {
        "confidence": {
          "type": "string",
          "enum": ["Confirmed", "Hypothesis"],
          "description": "Confidence level: Confirmed requires ≥2 independent signals + every causal step evidenced. Hypothesis if only 1 signal or any step inferred."
        },
        "confidence_rationale": {
          "type": "string",
          "description": "Explanation of why this confidence level was chosen — cite signal count, evidence quality, and whether alternatives were ruled out"
        },
        "failure_domain": {
          "type": "string",
          "description": "Where the failure originated. Can be: service name, database, network, infrastructure, configuration, or other. NOT the most visible victim — the true source."
        },
        "failure_mode": {
          "type": "string",
          "description": "Type of failure that occurred",
          "enum": [
            "crash",
            "oom",
            "connection_refused",
            "dns_failure",
            "db_timeout",
            "db_connection_pool_exhausted",
            "config_error",
            "dependency_unavailable",
            "instrumentation_gap",
            "network_latency",
            "network_partition",
            "resource_exhaustion",
            "infrastructure_throttling",
            "dns_misconfiguration",
            "dns_misconfiguration_and_startup_failure",
            "other"
          ]
        },
        "summary": {
          "type": "string",
          "description": "One sentence summary of the root cause, naming the failure domain and mode"
        },
        "causal_chain": {
          "type": "array",
          "description": "Step-by-step causal chain from root cause to visible symptoms",
          "items": {
            "type": "object",
            "required": ["step", "time_utc", "service", "event", "mechanism", "evidence"],
            "properties": {
              "step": {
                "type": "integer",
                "description": "Step number in the chain"
              },
              "time_utc": {
                "type": "string",
                "description": "UTC timestamp or time window"
              },
              "service": {
                "type": "string",
                "description": "Service or component involved"
              },
              "event": {
                "type": "string",
                "description": "What happened at this step (factual, no interpretation)"
              },
              "mechanism": {
                "type": "string",
                "description": "How this step caused the next one — the propagation link"
              },
              "evidence": {
                "type": "string",
                "description": "Verbatim evidence from logs, metrics, or traces — no paraphrasing"
              }
            }
          }
        },
        "contributing_factors": {
          "type": "array",
          "description": "Secondary factors that amplified or contributed to the failure",
          "items": {
            "type": "string"
          }
        },
        "alternatives_considered": {
          "type": "array",
          "description": "Alternative hypotheses that were considered and why they were rejected",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "description": "Evidence citations supporting the root cause",
      "items": {
        "type": "object",
        "required": ["signal", "description"],
        "properties": {
          "signal": {
            "type": "string",
            "enum": ["logs", "metrics", "traces"],
            "description": "Source signal type"
          },
          "description": {
            "type": "string",
            "description": "Citation from the signal (exact log line, metric value, trace ID)"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Actionable remediation and prevention steps",
      "items": {
        "type": "object",
        "required": ["action", "priority", "rationale"],
        "properties": {
          "action": {
            "type": "string",
            "description": "Specific remediation or prevention action"
          },
          "priority": {
            "type": "string",
            "enum": ["immediate", "short-term", "long-term"],
            "description": "When this action should be taken"
          },
          "rationale": {
            "type": "string",
            "description": "Why this action addresses the root cause or contributing factor"
          }
        }
      }
    },
    "impact": {
      "type": "string",
      "description": "Description of the impact on end-user functionality and system behavior"
    },
    "metadata": {
      "type": "object",
      "description": "Metadata about the analysis process",
      "properties": {
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp when the analysis was generated"
        },
        "reasoning_phases_completed": {
          "type": "array",
          "description": "Which CoT phases were completed",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7
          }
        },
        "validation_warnings": {
          "type": "array",
          "description": "Any schema validation warnings",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
